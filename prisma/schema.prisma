generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RSVP {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String
  email      String?
  attending  String
  guestCount Int?
  message    String?
  createdAt  DateTime @default(now())
}
